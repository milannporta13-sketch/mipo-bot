<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Mipo Bot Dashboard</title>

<style>
body{
  margin:0;
  font-family:Arial;
  background:#0b0d10;
  color:white;
}

/* HEADER */
header{
  background:#11151b;
  padding:20px;
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.logo{
  font-size:20px;
  font-weight:bold;
}

/* BUTTON */
.btn{
  background:#5865F2;
  padding:10px 15px;
  border-radius:8px;
  color:white;
  text-decoration:none;
  font-weight:bold;
}

.btn:hover{
  background:#4752c4;
}

/* CONTAINER */
.container{
  padding:40px;
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
  gap:20px;
}

/* CARD */
.card{
  background:#161b22;
  padding:20px;
  border-radius:15px;
  transition:0.2s;
}

.card:hover{
  transform:scale(1.03);
}

h2{
  margin-top:0;
}
</style>
</head>

<body>

<header>
  <div class="logo">🤖 Mipo Bot Dashboard</div>

  <a class="btn" href="https://discord.com/login">
    🔵 Se connecter
  </a>
</header>

<div class="container">

  <div class="card">
    <h2>📊 Stats Bot</h2>
    <p>Serveurs : --</p>
    <p>Utilisateurs : --</p>
  </div>

  <div class="card">
    <h2>⚙️ Paramètres</h2>
    <p>Configurer ton bot ici</p>
  </div>

  <div class="card">
    <h2>📢 Support</h2>
    <p>Rejoins le serveur Discord</p>
    <a class="btn" href="https://discord.com/invite/xxxxx">Rejoindre</a>
  </div>

</div>

</body>
</html>
